{
	"$schema": "https://turbo.build/schema.json",
	"tasks": {
		"dev": {
			"cache": false,
			"persistent": true
		},
		"build": {
			"dependsOn": ["^build"],
			"outputs": [".next/**", "dist/**"]
		},
		"lint": {
			"dependsOn": ["^lint"],
			"outputs": []
		},
		"lint:fix": {
			"cache": false,
			"outputs": []
		},
		"test": {
			"dependsOn": ["^test"],
			"outputs": []
		}
	}
}
